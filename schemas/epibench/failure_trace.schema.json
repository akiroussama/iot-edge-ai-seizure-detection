{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/akiroussama/iot-edge-ai-seizure-detection/schemas/epibench/failure_trace.schema.json",
  "title": "EpiBench Failure Trace",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "sentinels", "failure_policy", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "epibench.failure_trace.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "failure_policy": { "type": "string", "enum": ["preserve_all", "invalid_trace"] },
    "sentinels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "present", "severity", "count", "scope", "evidence"],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "PREDICTION_MISSING",
              "SEGMENT_CRASH",
              "NAN_OR_INF_OUTPUT",
              "LATENCY_BUDGET_EXCEEDED",
              "POST_EVENT_ALARM",
              "FAR_EXPLOSION",
              "PATIENT_LEAKAGE",
              "TEMPORAL_LEAKAGE",
              "SPLIT_NONCOMPLIANT",
              "LABEL_UNAUDITED",
              "DEVICE_MISSINGNESS",
              "DENOMINATOR_RESTRICTION",
              "HARDWARE_UNMEASURED"
            ]
          },
          "present": { "type": "boolean" },
          "severity": { "type": "string", "enum": ["none", "warning", "major", "critical"] },
          "count": { "type": "integer", "minimum": 0 },
          "scope": { "type": "string", "enum": ["none", "segment", "patient", "fold", "run", "dataset"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical_failure_present", "blocking_failure_present", "failure_rate"],
      "properties": {
        "critical_failure_present": { "type": "boolean" },
        "blocking_failure_present": { "type": "boolean" },
        "failure_rate": { "type": "number", "minimum": 0 }
      }
    }
  }
}
