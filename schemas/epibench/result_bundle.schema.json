{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/akiroussama/iot-edge-ai-seizure-detection/schemas/epibench/result_bundle.schema.json",
  "title": "EpiBench Result Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "track",
    "requested_claim",
    "dataset_card_path",
    "split_manifest_path",
    "failure_trace_path",
    "model",
    "environment",
    "inputs",
    "outputs",
    "metrics",
    "score_inputs",
    "reproduction"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "epibench.result_bundle.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "track": { "type": "string", "enum": ["D", "W", "F", "E"] },
    "requested_claim": { "type": "string", "enum": ["E0", "E1", "E2-PD", "E2-PI", "E3", "E4"] },
    "dataset_card_path": { "type": "string", "minLength": 1 },
    "split_manifest_path": { "type": "string", "minLength": 1 },
    "failure_trace_path": { "type": "string", "minLength": 1 },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "family", "commit_sha"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "commit_sha": { "type": "string", "minLength": 1 }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "platform", "dependencies"],
      "properties": {
        "python": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inputs": { "type": "array", "items": { "$ref": "#/$defs/artifact_ref" } },
    "outputs": { "type": "array", "items": { "$ref": "#/$defs/artifact_ref" } },
    "metrics": {
      "type": "object",
      "additionalProperties": { "type": ["number", "integer", "string", "boolean", "null"] }
    },
    "score_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subscores"],
      "properties": {
        "subscores": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 },
          "minProperties": 1
        }
      }
    },
    "hardware": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["target", "latency_ms_p95", "ram_kb", "energy_mj_per_inference"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "latency_ms_p95": { "type": ["number", "null"], "minimum": 0 },
        "ram_kb": { "type": ["number", "null"], "minimum": 0 },
        "energy_mj_per_inference": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "container_or_env", "checksums"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "container_or_env": { "type": "string", "minLength": 1 },
        "checksums": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": ["string", "null"] }
      }
    }
  }
}
