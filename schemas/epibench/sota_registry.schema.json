{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/akiroussama/iot-edge-ai-seizure-detection/schemas/epibench/sota_registry.schema.json",
  "title": "EpiBench SOTA Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verified_on", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "epibench.sota_registry.v1" },
    "verified_on": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_title",
          "url_or_doi",
          "year",
          "category",
          "relationship",
          "epibench_field_or_rule",
          "citation_integrity_status"
        ],
        "properties": {
          "source_title": { "type": "string", "minLength": 1 },
          "url_or_doi": { "type": "string", "minLength": 1 },
          "year": { "type": "integer", "minimum": 1900 },
          "category": {
            "type": "string",
            "enum": [
              "dataset",
              "scoring_framework",
              "reporting_guideline",
              "regulatory_guidance",
              "model_baseline",
              "clinical_standard"
            ]
          },
          "relationship": { "type": "string", "enum": ["ADOPT", "MAP", "EXTEND", "DIVERGE"] },
          "epibench_field_or_rule": { "type": "string", "minLength": 1 },
          "citation_integrity_status": { "type": "string", "enum": ["verified", "unverified", "rejected"] }
        }
      }
    }
  }
}
