{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/akiroussama/iot-edge-ai-seizure-detection/schemas/gate_c_registry.schema.json",
  "title": "EpiTwin Gate C artifact registry",
  "description": "Frozen artifact manifest for citable benchmark rows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "dataset",
    "dataset_version",
    "source_uri",
    "gate_c_status",
    "freeze_status",
    "doi_or_prereg_uri",
    "generation_command",
    "split_manifest",
    "artifacts",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "gate_c.registry.v1"
    },
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset": {
      "type": "string",
      "minLength": 1
    },
    "dataset_version": {
      "type": "string",
      "minLength": 1
    },
    "source_uri": {
      "type": "string",
      "minLength": 1
    },
    "gate_c_status": {
      "type": "string",
      "enum": ["not_started", "partial", "passed", "failed"]
    },
    "freeze_status": {
      "type": "string",
      "enum": ["engineering_scaffold", "pending_human_audit", "frozen", "failed"]
    },
    "doi_or_prereg_uri": {
      "type": ["string", "null"]
    },
    "generation_command": {
      "type": "string",
      "minLength": 1
    },
    "split_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["split_policy", "split_ids", "split_ref"],
      "properties": {
        "split_policy": {
          "type": "string",
          "minLength": 1
        },
        "split_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "split_ref": {
          "type": "string",
          "minLength": 1
        },
        "horizon_name": {
          "type": ["string", "null"]
        },
        "sph_minutes": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "sop_minutes": {
          "type": ["number", "null"],
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["name", "role", "path", "sha256", "bytes"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "role": {
            "type": "string",
            "enum": [
              "raw",
              "processed",
              "events",
              "windows",
              "labels",
              "features",
              "splits",
              "predictions",
              "metadata"
            ]
          },
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0},
          "row_count": {"type": "integer", "minimum": 0},
          "event_count": {"type": "integer", "minimum": 0},
          "positive_windows": {"type": "integer", "minimum": 0},
          "split_counts": {
            "type": "object",
            "additionalProperties": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
